---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        margin: auto;
        padding: 1em;
        width: 800px;
        max-width: calc(100% - 2em);
        color: rgb(var(--gray-dark));
        font-size: 20px;
        line-height: 1.6;
      }
      .hero {
        padding: 4em 0 2em 0;
        text-align: center;
      }
      .hero h1 {
        font-size: 3em;
        margin-bottom: 0.25em;
      }
      .hero p {
        color: rgb(var(--gray));
        font-size: 1.1em;
        margin-bottom: 2em;
      }
      .hero .cta {
        display: inline-flex;
        gap: 1em;
        flex-wrap: wrap;
        justify-content: center;
      }
      .btn {
        display: inline-block;
        padding: 0.6em 1.4em;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9em;
      }
      .btn-primary {
        background: var(--accent);
        color: white;
      }
      .btn-secondary {
        background: transparent;
        color: var(--accent);
        border: 2px solid var(--accent);
      }
      .section-title {
        font-size: 1.5em;
        border-bottom: 2px solid rgb(var(--gray-light));
        padding-bottom: 0.5em;
        margin-bottom: 1em;
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0 0 2em 0;
      }
      .post-list li {
        margin-bottom: 1.5em;
      }
      .post-list a {
        text-decoration: none;
        color: rgb(var(--black));
        font-weight: 700;
        font-size: 1.1em;
      }
      .post-list a:hover {
        color: var(--accent);
      }
      .post-meta {
        color: rgb(var(--gray));
        font-size: 0.875em;
        margin-top: 0.2em;
      }
      .view-all {
        text-align: right;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>SAGreenXYZ</h1>
        <p>Personal blog, portfolio, and knowledge base.</p>
        <div class="cta">
          <a href="/blog" class="btn btn-primary">Read the Blog</a>
          <a href="/about" class="btn btn-secondary">About Me</a>
        </div>
      </section>

      <section>
        <h2 class="section-title">Recent Posts</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <div class="post-meta">
                <FormattedDate date={post.data.pubDate} />
                {post.data.description && <span> — {post.data.description}</span>}
              </div>
            </li>
          ))}
        </ul>
        <div class="view-all">
          <a href="/blog">View all posts →</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
