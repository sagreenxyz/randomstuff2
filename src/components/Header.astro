    <div class="internal-links">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </div>
    <div class="social-links">
      <a href="/rss.xml" title="RSS Feed">
        <span class="sr-only">RSS Feed</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256">
          <path d="M200,224a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8,120.13,120.13,0,0,0-120-120,8,8,0,0,1-8-8V64a8,8,0,0,1,8-8A184.18,184.18,0,0,1,208,240,8,8,0,0,1,200,224Zm-96,0a8,8,0,0,1-8,8H64a8,8,0,0,1-8-8,72.08,72.08,0,0,0-72-72,8,8,0,0,1-8-8V112a8,8,0,0,1,8-8A136.15,136.15,0,0,1,120,240,8,8,0,0,1,104,224ZM72,224a8,8,0,0,1-8,8H32a8,8,0,0,1-8-8v-8a24,24,0,0,1,24-24h8a8,8,0,0,1,8,8Z" fill="currentColor"/>
